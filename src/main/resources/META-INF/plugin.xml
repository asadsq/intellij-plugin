<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.asadsq.intellijplugin</id>
    <name>intellij-plugin</name>
    <vendor>asadsq</vendor>
    <description><![CDATA[
        <p><b>Folder Highlighter</b> makes the Project view easier to read.</p>
        <p>When you select a folder, its full contents are highlighted with a subtle, theme-aware background tint &mdash; so you can see at a glance which files belong to that folder, no matter how deep or misleading the indentation gets.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Folder Highlighter: tints the full contents of the selected folder in the Project view -->
        <projectViewNodeDecorator implementation="com.github.asadsq.intellijplugin.folderhighlight.FolderHighlightNodeDecorator" />
        <postStartupActivity implementation="com.github.asadsq.intellijplugin.folderhighlight.FolderHighlightInstaller" />
        <!-- Diff Jump: floating next/prev navigation pill in text diff viewers -->
        <diff.DiffExtension implementation="com.github.asadsq.intellijplugin.diffjump.DiffJumpExtension"/>
    </extensions>

    <actions>
        <action id="DiffJump.Next"
                class="com.github.asadsq.intellijplugin.diffjump.JumpToNextDiffAction">
            <add-to-group group-id="Diff.EditorPopupMenu" anchor="last"/>
        </action>
        <action id="DiffJump.Previous"
                class="com.github.asadsq.intellijplugin.diffjump.JumpToPreviousDiffAction">
            <add-to-group group-id="Diff.EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
